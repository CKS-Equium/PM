{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "WebFetch",
      "WebSearch",
      "Bash",
      "PowerShell",
      "Edit(.claude/agents/**/notes.md)"
    ],
    "ask": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git branch -D:*)",
      "Bash(git checkout --:*)",
      "Bash(gh repo delete:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)"
    ]
  }
}
